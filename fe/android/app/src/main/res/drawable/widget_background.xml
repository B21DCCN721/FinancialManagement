<?xml version="1.0" encoding="utf-8"?>
<!--
    widget_background.xml — Nền widget tối glassmorphism
    Bo góc 16dp, nền tối với gradient tím nhẹ
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#E6110E1E" />
    <corners android:radius="16dp" />
    <stroke
        android:width="1dp"
        android:color="#3A2A5A" />
</shape>
