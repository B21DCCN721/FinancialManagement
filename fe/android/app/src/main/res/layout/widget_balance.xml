<?xml version="1.0" encoding="utf-8"?>
<!--
    widget_balance.xml — Layout cho FinManage Balance Widget
    Kích thước tối thiểu: 4 cells ngang × 2 cells dọc (~250dp × 110dp)
    Thiết kế: Dark glassmorphism, gradient tím-xanh của FinManage
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background"
    android:gravity="center_vertical">

    <!-- Header: App name + icon -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@mipmap/ic_launcher_round"
            android:contentDescription="FinManage" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="@string/widget_app_name"
            android:textColor="#B0A8FF"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.05" />

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/widget_updated_at"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_not_updated"
            android:textColor="#8888AA"
            android:textSize="9sp" />

    </LinearLayout>

    <!-- Divider -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2A4A"
        android:layout_marginBottom="8dp" />

    <!-- Label số dư -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_balance_label"
        android:textColor="#9090BB"
        android:textSize="10sp"
        android:layout_marginBottom="2dp" />

    <!-- Số tiền số dư (lớn, nổi bật) -->
    <TextView
        android:id="@+id/widget_balance_amount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 ₫"
        android:textColor="#10D9A0"
        android:textSize="22sp"
        android:fontFamily="sans-serif-bold"
        android:layout_marginBottom="8dp" />

    <!-- Row Income / Expense -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Thu nhập -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/widget_stat_bg_green"
            android:padding="6dp"
            android:layout_marginEnd="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_income_label"
                android:textColor="#80C8B0"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/widget_income_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ 0 ₫"
                android:textColor="#10D9A0"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- Chi tiêu -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/widget_stat_bg_red"
            android:padding="6dp"
            android:layout_marginStart="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_expense_label"
                android:textColor="#C88080"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/widget_expense_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="- 0 ₫"
                android:textColor="#FF4D6D"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
